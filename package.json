{
  "name": "claude-ipc",
  "version": "0.0.1",
  "description": "Cross-process messaging between independently-launched Claude Code sessions",
  "type": "module",
  "private": true,
  "bin": {
    "claude-ipc": "./src/cli.ts"
  },
  "scripts": {
    "broker": "bun run src/broker/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "build:cli": "bun build src/cli.ts --compile --outfile dist/claude-ipc",
    "build:hooks": "bun build src/hooks/userPromptSubmit.ts --compile --outfile dist/ipc-ups"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6",
    "@types/bun": "latest"
  }
}
